# Cortex environment template. Copy to .env and fill in. NEVER commit .env.
# Settings are loaded via pydantic-settings (see cortex.api.config).

# --- Core ---
CORTEX_ENV=local                 # local | staging | prod
LOG_LEVEL=INFO

# --- Datastores (defaults match infra/docker-compose.yml) ---
POSTGRES_DSN=postgresql+asyncpg://cortex:cortex@localhost:5432/cortex
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# --- Eval quality gate ---
# advisory: report metrics but never fail the build (default until a real golden
#           set exists). blocking: fail CI when a threshold regresses.
EVAL_GATE=advisory

# --- LLM provider (extraction + generation; provider-agnostic) ---
LLM_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Source connector credentials (OAuth) — leave blank until M0/M3 ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_TOKEN=
GITHUB_TOKEN=
LINEAR_API_KEY=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cortex-api
